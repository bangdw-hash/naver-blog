# ============================================================
# 네이버 블로그 자동화 - 전체 환경변수 관리 파일
# 이 파일을 복사해서 .env 로 저장 후 실제 값 입력
# .env 파일은 절대 GitHub에 올리지 마세요!
# ============================================================

# ── AI 글 생성 ───────────────────────────────────────────
# 발급: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-여기에입력

# ── AI 이미지 생성 (DALL-E 3) ────────────────────────────
# 발급: https://platform.openai.com/api-keys
# 비용: 이미지 1장당 약 $0.04 (1024x1024 standard)
OPENAI_API_KEY=sk-proj-여기에입력

# ── 네이버 계정 ──────────────────────────────────────────
NAVER_ID=네이버아이디
NAVER_PW=네이버비밀번호

# ── 이력 DB (Supabase - 무료) ────────────────────────────
# 발급: https://supabase.com → New Project → Settings → API
# SUPABASE_URL 예시: https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=https://여기에입력.supabase.co
SUPABASE_KEY=eyJ여기에입력

# ── 웹앱 설정 ────────────────────────────────────────────
SECRET_KEY=나만의비밀키아무거나입력
PORT=5000
# 파일 저장 경로 (로컬 PC 기준, 모바일은 앱 내에서 설정)
UPLOAD_DIR=./uploads
IMAGE_DIR=./uploads/images

# ── 블로그 설정 ──────────────────────────────────────────
NAVER_CATEGORY_NO=0
NAVER_CATEGORY_NAME=전체
AUTO_POST_TIME=09:00
BLOG_CONCEPT=학부모와 학생을 위한 실용적인 교육 정보를 따뜻하고 친근한 톤으로 전달
